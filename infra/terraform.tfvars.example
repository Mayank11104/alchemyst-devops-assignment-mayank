# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored and must never be committed.

# AWS EC2 key pair name (must already exist in your AWS account)
key_pair_name = "your-key-pair-name"

# Your public IP in CIDR notation for SSH access to the API gateway
# Find it by running: curl https://checkip.amazonaws.com
my_ip_cidr = "YOUR.PUBLIC.IP/32"

# Optional overrides (defaults are set in variables.tf)
# inference_instance_type   = "t3.xlarge"   # production: 8 GB RAM needed for model
# caller_instance_type      = "t3.small"
# api_gateway_instance_type = "t3.micro"
# aws_region                = "ap-south-1"
